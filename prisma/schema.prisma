generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SkillCategory {
  GRAPHIC_DESIGN
  SOCIAL_MEDIA
  PHOTOGRAPHY
  WEBSITE
  MARKETING
  BRANDING
  FINANCE
  PITCH_DECK
  CONTENT
  OTHER
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  EXPERT
}

enum ExchangeStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
  COMPLETED
}

enum TransactionType {
  EXCHANGE
  REWARD
  PURCHASE
}

model User {
  id            String   @id @default(cuid())
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  bio           String?
  age           Int?
  location      String?
  bizCoins      Int      @default(100)
  hasOnboarded  Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  businessProfile   BusinessProfile?
  skills            Skill[]
  accounts          Account[]
  sessions          Session[]
  sentExchanges     ExchangeRequest[] @relation("SentExchanges")
  receivedExchanges ExchangeRequest[] @relation("ReceivedExchanges")
  transactionsFrom  Transaction[]     @relation("TransactionsFrom")
  transactionsTo    Transaction[]     @relation("TransactionsTo")
  reviewsGiven      Review[]          @relation("ReviewsGiven")
  reviewsReceived   Review[]          @relation("ReviewsReceived")

  @@map("users")
}

model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  businessName    String
  industry        String?
  description     String?
  stage           String?
  website         String?
  instagramHandle String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

model Skill {
  id          String        @id @default(cuid())
  userId      String
  title       String
  category    SkillCategory
  description String?
  level       SkillLevel?
  isOffering  Boolean       @default(true)
  isDeleted   Boolean       @default(false)
  coinValue   Int           @default(10)
  createdAt   DateTime      @default(now())

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  offeredIn    ExchangeRequest[] @relation("OfferedSkill")
  requestedIn  ExchangeRequest[] @relation("RequestedSkill")

  @@map("skills")
}

model ExchangeRequest {
  id               String         @id @default(cuid())
  fromUserId       String
  toUserId         String
  offeredSkillId   String
  requestedSkillId String
  message          String?
  status           ExchangeStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  fromUser        User          @relation("SentExchanges", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User          @relation("ReceivedExchanges", fields: [toUserId], references: [id], onDelete: Cascade)
  offeredSkill    Skill         @relation("OfferedSkill", fields: [offeredSkillId], references: [id])
  requestedSkill  Skill         @relation("RequestedSkill", fields: [requestedSkillId], references: [id])
  transactions    Transaction[]
  reviews         Review[]

  @@map("exchange_requests")
}

model Transaction {
  id                String          @id @default(cuid())
  fromUserId        String?
  toUserId          String
  amount            Int
  type              TransactionType
  description       String?
  relatedExchangeId String?
  createdAt         DateTime        @default(now())

  fromUser        User?            @relation("TransactionsFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser          User             @relation("TransactionsTo", fields: [toUserId], references: [id], onDelete: Cascade)
  exchange        ExchangeRequest? @relation(fields: [relatedExchangeId], references: [id])

  @@map("transactions")
}

model Review {
  id         String   @id @default(cuid())
  reviewerId String
  revieweeId String
  exchangeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  reviewer User            @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewee User            @relation("ReviewsReceived", fields: [revieweeId], references: [id], onDelete: Cascade)
  exchange ExchangeRequest @relation(fields: [exchangeId], references: [id])

  @@unique([reviewerId, exchangeId])
  @@map("reviews")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
